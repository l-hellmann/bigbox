// Gun-themed starter affix set. No magic, no elemental fantasy — this is a
// zombie shooter, not a spellcaster RPG. Damage types are real ammunition /
// firearm mod archetypes (hollow-point, incendiary, armor-piercing, explosive).
//
// Tiers numbered T1 (best) → T4 (worst); ilvl_required gates availability;
// weight controls relative frequency within the affix. Curve across tiers:
// weight 1000/600/300/100 at ilvl 1/20/40/60.
//
// Weapon affixes are split by archetype because flat damage scales with fire
// rate — a +10 flat bullet roll is 100 DPS on an SMG and 5 DPS on a rocket.
// Rapid-fire damage affixes (pistol/SMG) keep small per-shot values; heavy
// damage affixes (shotgun/rocket) carry ~10× values so per-second DPS lines up.
//
// Pool shape (relevant for rare affix-count target 3-4 / Epic 4-5 / Leg 5-6):
//   rapid_fire prefix groups: 5 (4 rapid damage + weapon_damage inc)
//   heavy prefix groups:      5 (4 heavy damage  + weapon_damage inc)
//   weapon suffix groups:     3 (fire rate, crit chance, crit damage)
//                             + 4 universal suffixes below
//   Armor prefix groups:      4 (life, armor, evasion, thorns)
//   Armor suffix groups:      4 universal (regen + melee/ranged red + move spd)
[
    // ---------- rapid-fire weapon prefixes ----------
    (
        id: "flat_bullet_damage",
        name_fragment: "Hollow-Point",
        slot: prefix,
        group: "bullet_dmg_flat",
        allowed_categories: ["rapid_fire"],
        tiers: [
            (tier: 4, ilvl_required:  1, weight: 1000, stats: [(stat: "bullet_damage", kind: flat, min:  5.0, max: 10.0)]),
