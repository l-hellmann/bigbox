// Gun/military-themed base items. Per v1 scope in CLAUDE.md:
//   Weapons: 4 archetypes — pistol, shotgun, SMG, rocket launcher
//   Armor:   3 slots      — helm, chest, boots
//
// Weapons split into two archetype categories so flat-damage affixes can be
// scaled per class (a +10 flat-damage roll is 100 DPS on an SMG vs 5 DPS on a
// rocket — affixes have to compensate, not the base damage):
//   rapid_fire — pistol, SMG  (low per-shot damage, high fire rate)
//   heavy      — shotgun, rocket_launcher (high per-shot, low fire rate)
//
// Intrinsic stats below are *base* values in the three-tier stat formula —
// affixes layer on top. Zero-affix DPS:
//   pistol           = damage 12  × rate 4.0  = 48
//   shotgun          = damage 36  × rate 1.0  = 36
//   smg              = damage  5  × rate 10.0 = 50
//   rocket_launcher  = damage 80  × rate 0.5  = 40
[
    // ---------- rapid-fire weapons ----------
    (
        id: "pistol",
        name: "Pistol",
        category: "rapid_fire",
        slot: "weapon",
        intrinsic_stats: [
            (stat: "weapon_damage", value: 12.0),
            (stat: "fire_rate",     value:  4.0),
            (stat: "magazine_size", value: 12.0),
            (stat: "reload_time",   value:  1.5),
        ],
    ),
    (
        id: "smg",
        name: "SMG",
        category: "rapid_fire",
        slot: "weapon",
        intrinsic_stats: [
            (stat: "weapon_damage", value:  5.0),
            (stat: "fire_rate",     value: 10.0),
            (stat: "magazine_size", value: 30.0),
            (stat: "reload_time",   value:  2.0),
        ],
    ),

    // ---------- heavy weapons ----------
    (
        id: "shotgun",
        name: "Shotgun",
        category: "heavy",
        slot: "weapon",
        intrinsic_stats: [
            (stat: "weapon_damage", value: 36.0),
            (stat: "fire_rate",     value:  1.0),
            (stat: "magazine_size", value:  6.0),
            (stat: "reload_time",   value:  3.0),
        ],
    ),
    (
        id: "rocket_launcher",
        name: "Rocket Launcher",
        category: "heavy",
        slot: "weapon",
        intrinsic_stats: [
            (stat: "weapon_damage", value: 80.0),
            (stat: "fire_rate",     value:  0.5),
            (stat: "magazine_size", value:  2.0),
            (stat: "reload_time",   value:  4.0),
        ],
    ),

    // ---------- armor ----------
    (
        id: "combat_helmet",
        name: "Combat Helmet",
        category: "helm",
        slot: "helm",
        intrinsic_stats: [
            (stat: "life",    value: 30.0),
            (stat: "armor",   value: 20.0),
            (stat: "evasion", value:  5.0),
        ],
    ),
    (
        id: "tactical_vest",
        name: "Tactical Vest",
        category: "chest",
        slot: "chest",
        intrinsic_stats: [
            (stat: "life",    value: 60.0),
            (stat: "armor",   value: 40.0),
            (stat: "evasion", value: 10.0),
        ],
    ),
    (
        id: "combat_boots",
        name: "Combat Boots",
        category: "boots",
        slot: "boots",
        intrinsic_stats: [
            (stat: "life",    value: 20.0),
            (stat: "armor",   value: 10.0),
            (stat: "evasion", value: 15.0),
        ],
    ),
]
